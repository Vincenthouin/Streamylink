{
  "name": "music-share",
  "version": "1.0.0",
  "description": "Convertit un lien Qobuz/Spotify/Apple Music/Deezer vers les autres plateformes",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:chain": "tsx test-chain.ts",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder --mac dmg"
  },
  "keywords": [],
  "author": "UX Team",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "productName": "Music Share",
  "build": {
    "appId": "com.uxteam.musicshare",
    "productName": "Music Share",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "target": "dmg",
      "identity": null,
      "category": "public.app-category.music"
    },
    "dmg": {
      "title": "Music Share"
    }
  }
}
